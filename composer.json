{
  "name": "siimple-c/active-plugin-locator",
  "description": "Active Plugin Locator (WordPress plugin)",
  "type": "project",
  "require": {},
  "require-dev": {
      "squizlabs/php_codesniffer": "^3.10",
  "wp-coding-standards/wpcs": "^3.0",
  "phpcsstandards/phpcsextra": "^1.0",
  "phpcsstandards/phpcsutils": "^1.1"
  },
  "config": {
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true
    }
  },
  "scripts": {
    "lint": "phpcs -q",
    "lint:report": "phpcs"
  }
}